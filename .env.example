POSTGRES_USER=nerve_admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nerve

# Application role created by migrations/002_lock_down_app_role.sql.
# This role can only SELECT/INSERT on runs — never UPDATE/DELETE.
NERVE_APP_PASSWORD=changeme_too

# LiteLLM proxy (M2). Sole provider: Anthropic.
ANTHROPIC_API_KEY=sk-ant-changeme
LITELLM_MASTER_KEY=sk-changeme
LITELLM_SALT_KEY=changeme
LITELLM_BASE_URL=http://127.0.0.1:4000

# Virtual keys, generated by scripts/setup-litellm.sh into the real .env —
# do not set these by hand.
LITELLM_NORMALIZER_KEY=
LITELLM_ROUTER_KEY=
